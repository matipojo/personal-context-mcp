{
  "name": "personal-info-mcp-server",
  "version": "1.0.0",
  "description": "A TypeScript MCP server for managing personal information with scope-based permissions",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build:mcp-app": "vite build --config vite.mcp-app.config.ts",
    "build": "npm run build:mcp-app && tsc",
    "predev": "npm run build:mcp-app",
    "dev": "concurrently -n tsc,mcp-app -c blue,green \"tsc --watch\" \"vite build --watch --config vite.mcp-app.config.ts\"",
    "dev:mcp-app": "vite build --watch --config vite.mcp-app.config.ts",
    "dev:mcp-app:serve": "vite --config vite.mcp-app.config.ts",
    "start": "cross-env TZ=UTC node dist/index.js",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "inspect": "npm run build && npx @modelcontextprotocol/inspector \"node dist/index.js --data-dir ./data\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "personal-information",
    "typescript",
    "claude-desktop"
  ],
  "author": "Personal MCP Server",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.6.0",
    "@modelcontextprotocol/sdk": "^1.17.0",
    "@types/crypto-js": "^4.2.2",
    "@types/qrcode": "^1.5.5",
    "crypto-js": "^4.2.0",
    "fs-extra": "^11.3.0",
    "glob": "^11.0.3",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "yaml": "^2.8.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.5",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3",
    "vite": "^5.4.21",
    "vite-plugin-singlefile": "^2.3.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
